# Databricks workspace auth — used by databricks-langchain ChatDatabricks
# Either set these directly, or run `databricks auth login` and the SDK
# will pick up your default profile.
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_TOKEN=dapi...

# Foundation model endpoint served through the Unity AI Gateway
MODEL_ENDPOINT=databricks-gpt-5-5
