# Databricks workspace auth.
#
# Recommended: run `databricks auth login --profile <your-profile>` and then
# point this app at that profile (the Databricks SDK reads ~/.databrickscfg):
DATABRICKS_CONFIG_PROFILE=<your-profile-name>

# Alternative — host + PAT directly (not recommended, mirrors are easier):
# DATABRICKS_HOST=https://<your-workspace>.cloud.databricks.com
# DATABRICKS_TOKEN=<paste-personal-access-token>

# Foundation model endpoint served through the Unity AI Gateway.
MODEL_ENDPOINT=databricks-gpt-5-5
