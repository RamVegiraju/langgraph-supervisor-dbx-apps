# Databricks workspace auth.
DATABRICKS_CONFIG_PROFILE=<your-profile-name>

# Foundation model + embeddings.
MODEL_ENDPOINT=databricks-gpt-5-5
DATABRICKS_EMBEDDING_ENDPOINT=databricks-gte-large-en

# Lakebase Autoscale — set after running provision_lakebase.py.
LAKEBASE_AUTOSCALING_PROJECT=langgraph-supervisor-memory
LAKEBASE_AUTOSCALING_BRANCH=development

# Distillation cadence (opportunistic-at-session-start).
DISTILL_MIN_INTERVAL_HOURS=1
DISTILL_MIN_NEW_EPISODES=3
